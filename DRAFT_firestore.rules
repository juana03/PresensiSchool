rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Attendance Records
    match /records/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isValidId(recordId)
        && request.resource.data.id == recordId
        && request.resource.data.timestamp is string
        && request.resource.data.type in ['murid', 'guru']
        && request.resource.data.data is map;
      allow update, delete: if false;
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.id is number
        && request.resource.data.timestamp is string
        && request.resource.data.user is string
        && request.resource.data.action is string
        && request.resource.data.detail is string;
      allow update, delete: if false;
    }
  }
}
